# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Full documentation: README.md → Environment variables

# --- Required (Single Key from Optimizely CMS → Settings → Optimizely Graph) ---
NEXT_PUBLIC_SDK_KEY=your_optimizely_graph_single_key_here
OPTIMIZELY_GRAPH_SINGLE_KEY=your_optimizely_graph_single_key_here

# --- CMS instance (for live preview + dev menu links to CMS admin) ---
# Full URL — e.g. https://app-epsajjcmson91rm1p001.cms.optimizely.com
NEXT_PUBLIC_OPTIMIZELY_CMS_URL=https://app-your-instance-id.cms.optimizely.com
# Instance UUID only — used to build URLs if CMS_URL is omitted
NEXT_PUBLIC_OPTIMIZELY_CMS_INSTANCE_ID=your-instance-id

# --- Optional ---
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Not used by this app (safe to omit) ---
# OPTIMIZELY_GRAPH_SECRET=
# OPTIMIZELY_GRAPH_GATEWAY=https://cg.optimizely.com
# OPTIMIZELY_GRAPH_APP_KEY=
# OPTIMIZELY_DAM_ENABLED=false
# OPTIMIZELY_CLIENT_SECRET=

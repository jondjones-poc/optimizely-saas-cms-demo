# Copy to .env.local:
#   cp .env.example .env.local
# Or run: npm run setup
#
# Full documentation: README.md → Environment variables

# CMS Admin → Settings → Optimizely Graph → Render Content → Single Key
NEXT_PUBLIC_SDK_KEY=

# CMS Admin → browser address bar (no trailing slash)
NEXT_PUBLIC_OPTIMIZELY_CMS_URL=https://app-your-instance-id.cms.optimizely.com

# CMS Admin → Content tree → Main Website → ID in contentdata:/// link
NEXT_PUBLIC_OPTIMIZELY_CMS_ROOT_NODE_ID=7

# CMS Admin → Content tree → Main Website → URL path (must match CMS exactly; e.g. / or /en/)
OPTIMIZELY_HOMEPAGE_URL=/

# CMS Admin → Settings → API Keys → Manage Content API (server-only — never NEXT_PUBLIC_)
OPTIMIZELY_CMS_CLIENT_ID=
OPTIMIZELY_CMS_CLIENT_SECRET=

# Content tree → /poc page → content key (GUID, no hyphens) — parent for new POC pages
OPTIMIZELY_POC_PARENT_CONTENT_KEY=

# Page content type key to create (e.g. poc_page_type)
OPTIMIZELY_POC_PAGE_TYPE_KEY=poc_page_type

# Locale for new CMS content versions
OPTIMIZELY_CMS_LOCALE=en

# Optional — defaults to http://localhost:3000 if omitted
# NEXT_PUBLIC_OPTIMIZELY_CMS_INSTANCE_ID=your-instance-id

# Optional — defaults to http://localhost:3000 if omitted
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

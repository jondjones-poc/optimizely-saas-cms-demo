# Copy to .env.local:
#   cp .env.example .env.local

# CMS Admin → Settings → Optimizely Graph → Render Content → Single Key
NEXT_PUBLIC_SDK_KEY=

# CMS Admin → your instance URL (browser address bar, no trailing slash)
NEXT_PUBLIC_OPTIMIZELY_CMS_URL=https://app-yourinstance.cms.optimizely.com

# CMS Admin → Content tree → Main Website → ID in contentdata:/// link
NEXT_PUBLIC_OPTIMIZELY_CMS_ROOT_NODE_ID=7

# CMS Admin → Content tree → Main Website → URL path (Graph homepage query)
OPTIMIZELY_HOMEPAGE_URL=/en/
